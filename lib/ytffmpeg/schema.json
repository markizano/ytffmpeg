{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markizano.net/schemas/ytffmpeg.json",
  "title": "ytffmpeg Configuration Schema",
  "description": "Complete schema for ytffmpeg.yml configuration file",
  "type": "object",
  "properties": {
    "ytffmpeg": {
      "$id": "#/ytffmpeg",
      "title": "Global ytffmpeg Configuration",
      "description": "Global settings for video processing, subtitle generation, and Whisper transcription",
      "type": "object",
      "properties": {
        "language": {
          "$id": "#/ytffmpeg/language",
          "description": "Base language for Whisper transcription (ISO 639-1 two-letter code)",
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "default": "en",
          "examples": ["en", "es", "fr", "de", "pt", "ja", "zh", "ar"]
        },
        "languages": {
          "$id": "#/ytffmpeg/languages",
          "description": "Array of languages to include in final video. First language is generated by Whisper, additional languages are translated using Argos Translate",
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z]{2}$"
          },
          "uniqueItems": true,
          "examples": [["en", "es", "fr"], ["en"], ["en", "de", "pt"]]
        },
        "subtitles": {
          "$id": "#/ytffmpeg/subtitles",
          "description": "Enable or disable subtitle generation",
          "type": "boolean",
          "default": true
        },
        "whisper_model": {
          "$id": "#/ytffmpeg/whisper_model",
          "description": "Whisper model to use for transcription. If not specified, automatically selects based on GPU VRAM",
          "type": "string",
          "enum": ["tiny", "base", "small", "medium", "large", "large-v2", "large-v3"],
          "examples": ["large-v3", "medium", "small"]
        },
        "device": {
          "$id": "#/ytffmpeg/device",
          "description": "Device to use for Whisper transcription",
          "type": "string",
          "enum": ["cpu", "cuda", "auto"],
          "default": "cuda"
        },
        "whisper_temperature": {
          "$id": "#/ytffmpeg/whisper_temperature",
          "description": "Temperature for Whisper generation (lower = more deterministic)",
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.0
        },
        "overwrite": {
          "$id": "#/ytffmpeg/overwrite",
          "description": "Overwrite existing files during processing",
          "type": "boolean",
          "default": false
        },
        "cut_silence": {
          "$id": "#/ytffmpeg/cut_silence",
          "description": "Enable silence detection and removal from videos",
          "type": "boolean",
          "default": false
        },
        "silence_threshold": {
          "$id": "#/ytffmpeg/silence_threshold",
          "description": "Silence detection threshold in dB",
          "type": "number",
          "default": 30,
          "minimum": 0
        },
        "silence_duration": {
          "$id": "#/ytffmpeg/silence_duration",
          "description": "Minimum silence duration in seconds to be considered as silence",
          "type": "number",
          "default": 1.0,
          "minimum": 0
        },
        "silence_pad": {
          "$id": "#/ytffmpeg/silence_pad",
          "description": "Padding in milliseconds to add before/after silence removal",
          "type": "number",
          "default": 350,
          "minimum": 0
        },
        "delete_mp4": {
          "$id": "#/ytffmpeg/delete_mp4",
          "description": "Delete original MP4 files after MKV conversion",
          "type": "boolean",
          "default": false
        },
        "no_convert": {
          "$id": "#/ytffmpeg/no_convert",
          "description": "Skip MP4 to MKV conversion",
          "type": "boolean",
          "default": false
        },
        "resource": {
          "$id": "#/ytffmpeg/resource",
          "description": "Specific resource video to build (for ytffmpeg build command)",
          "type": "string"
        },
        "autoplay": {
          "$id": "#/ytffmpeg/autoplay",
          "description": "Automatically play videos after building",
          "type": "boolean",
          "default": true
        },
        "media_player": {
          "$id": "#/ytffmpeg/media_player",
          "description": "Media player to use for autoplay",
          "type": "string",
          "default": "mpv",
          "examples": ["mpv", "vlc", "ffplay"]
        },
        "defaults": {
          "$id": "#/ytffmpeg/defaults",
          "description": "Default configuration for all videos (can be overridden per-video)",
          "type": "object",
          "properties": {
            "metadata": {
              "$id": "#/ytffmpeg/defaults/metadata",
              "description": "Default metadata to apply to all videos",
              "type": "object",
              "patternProperties": {
                "^[a-zA-Z0-9:_-]+$": {
                  "type": "string"
                }
              },
              "examples": [{
                "author": "Markizano Draconus",
                "title": "Video Title",
                "description": "Video description",
                "comment": "Created with ytffmpeg",
                "website": "https://example.com",
                "date": "2024-09-17T17:30-0400"
              }]
            },
            "codecs": {
              "$id": "#/ytffmpeg/defaults/codecs",
              "description": "Default video and audio codecs",
              "type": "object",
              "properties": {
                "video": {
                  "type": "string",
                  "default": "libx265",
                  "examples": ["libx265", "libx264", "libvpx-vp9"]
                },
                "audio": {
                  "type": "string",
                  "default": "aac",
                  "examples": ["aac", "ac3", "opus", "libvorbis"]
                }
              }
            }
          }
        },
        "google": {
          "$id": "#/ytffmpeg/google",
          "title": "Google API Configuration",
          "description": "Google API settings for thumbnail generation",
          "type": "object",
          "properties": {
            "api_key": {
              "type": "string",
              "description": "Google API key for thumbnail generation service"
            }
          }
        }
      }
    },
    "videos": {
      "$id": "#/videos",
      "title": "Videos Configuration Array",
      "description": "Array of video processing configurations. Each entry defines inputs, outputs, filters, and metadata for a single video",
      "type": "array",
      "items": {
        "$id": "#/videos/item",
        "type": "object",
        "properties": {
          "attributes": {
            "$id": "#/videos/item/attributes",
            "description": "Processing attributes that customize how this video is built",
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["subs", "no-video", "no-audio", "vsync", "not-a-build"]
            },
            "uniqueItems": true,
            "examples": [["subs"], ["subs", "vsync"], ["no-audio"]]
          },
          "input": {
            "$id": "#/videos/item/input",
            "description": "Array of input sources (videos, images, subtitles). Each input is an object with ffmpeg options",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "i": {
                  "$id": "#/videos/item/input/i",
                  "description": "Input file path (required)",
                  "type": "string",
                  "examples": ["build/video.mkv", "resources/image.png", "build/video.en.srt"]
                },
                "f": {
                  "$id": "#/videos/item/input/f",
                  "description": "Force input format (ffmpeg -f option)",
                  "type": "string",
                  "examples": ["lavfi", "matroska", "mp4"]
                },
                "t": {
                  "$id": "#/videos/item/input/t",
                  "description": "Duration to extract from input (in seconds)",
                  "type": "string",
                  "pattern": "^\\d+(\\.\\d+)?$",
                  "examples": ["5", "10.5", "30"]
                },
                "ss": {
                  "$id": "#/videos/item/input/ss",
                  "description": "Start time offset (seek position) as timestamp or seconds",
                  "type": "string",
                  "examples": ["00:01:30", "90", "1:30.5"]
                },
                "to": {
                  "$id": "#/videos/item/input/to",
                  "description": "End time as timestamp or seconds",
                  "type": "string",
                  "examples": ["00:05:00", "300", "5:00"]
                },
                "loop": {
                  "$id": "#/videos/item/input/loop",
                  "description": "Loop the input (useful for images)",
                  "type": "string",
                  "enum": ["true", "false"],
                  "examples": ["true"]
                },
                "framerate": {
                  "$id": "#/videos/item/input/framerate",
                  "description": "Input framerate for images",
                  "type": "string",
                  "pattern": "^\\d+(\\.\\d+)?$",
                  "examples": ["30", "60", "23.976"]
                }
              },
              "required": ["i"],
              "additionalProperties": true
            },
            "minItems": 1
          },
          "output": {
            "$id": "#/videos/item/output",
            "description": "Output file path",
            "type": ["string", "null"],
            "examples": ["build/output.mp4", "build/video.mkv"]
          },
          "filter_complex": {
            "$id": "#/videos/item/filter_complex",
            "description": "FFmpeg filter_complex definitions. Can be strings (raw ffmpeg syntax) or objects (structured format)",
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Raw FFmpeg filter_complex string",
                  "examples": [
                    "[0:v]scale=1920:1080[video]",
                    "[0:a]volume=1.5,asetpts=PTS-STARTPTS[audio]",
                    "[0:v]subtitles=build/video.en.srt:force_style='Alignment=0,FontName=Impact'[video]"
                  ]
                },
                {
                  "type": "object",
                  "description": "Structured filter definition",
                  "properties": {
                    "istream": {
                      "description": "Input stream(s)",
                      "oneOf": [
                        {"type": "string"},
                        {"type": "array", "items": {"type": "string"}, "minItems": 1}
                      ],
                      "examples": ["[0:v]", "[1:a]", ["[0:v]", "[1:v]"]]
                    },
                    "filters": {
                      "description": "Array of filter functions to apply",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      },
                      "examples": [[
                        {"scale": {"width": 1920, "height": 1080}},
                        {"setsar": ["1:1"]}
                      ]]
                    },
                    "funcs": {
                      "description": "Alias for filters",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "ostream": {
                      "description": "Output stream(s)",
                      "oneOf": [
                        {"type": "string"},
                        {"type": "array", "items": {"type": "string"}, "minItems": 1}
                      ],
                      "examples": ["[video]", "[audio]", ["[v1]", "[v2]"]]
                    }
                  },
                  "required": ["istream", "ostream"]
                }
              ]
            }
          },
          "metadata": {
            "$id": "#/videos/item/metadata",
            "description": "Metadata to attach to the output video",
            "type": "object",
            "patternProperties": {
              "^[a-zA-Z0-9:_-]+$": {
                "type": "string"
              }
            },
            "examples": [{
              "title": "My Video",
              "author": "John Doe",
              "description": "Video description",
              "date": "2024-01-01",
              "comment": "Additional comments"
            }]
          },
          "languages": {
            "$id": "#/videos/item/languages",
            "description": "Language codes with stream indices for multi-language subtitle support",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{2}:[0-9]+$"
            },
            "uniqueItems": true,
            "examples": [["en:0", "es:1", "fr:2"], ["en:0"]]
          },
          "map": {
            "$id": "#/videos/item/map",
            "description": "Stream mapping for video, audio, subtitles, and language-specific subtitle tracks",
            "type": "object",
            "properties": {
              "video": {
                "type": "string",
                "description": "Video stream mapping",
                "examples": ["[video]", "0:v"]
              },
              "audio": {
                "type": "string",
                "description": "Audio stream mapping",
                "examples": ["[audio]", "0:a"]
              },
              "subs": {
                "type": "string",
                "description": "Subtitle stream mapping (single language mode)",
                "examples": ["[subs]", "1:s"]
              }
            },
            "patternProperties": {
              "^[a-z]{2}$": {
                "type": "string",
                "pattern": "^[0-9]+:s$",
                "description": "Language-specific subtitle stream mapping"
              }
            },
            "examples": [{
              "video": "[video]",
              "audio": "[audio]",
              "en": "1:s",
              "es": "2:s"
            }]
          },
          "codecs": {
            "$id": "#/videos/item/codecs",
            "description": "Video and audio codec overrides for this specific video",
            "type": "object",
            "properties": {
              "video": {
                "type": "string",
                "examples": ["libx265", "libx264", "libvpx-vp9"]
              },
              "audio": {
                "type": "string",
                "examples": ["aac", "ac3", "opus"]
              }
            }
          },
          "language": {
            "$id": "#/videos/item/language",
            "description": "Default language for this video (overrides global language setting)",
            "type": "string",
            "pattern": "^[a-z]{2}$",
            "examples": ["en", "es", "fr"]
          },
          "require": {
            "$id": "#/videos/item/require",
            "description": "Dependencies - other videos that must be built before this one",
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ],
            "examples": ["build/intro.mp4", ["build/intro.mp4", "build/outro.mp4"]]
          },
          "thumbnail": {
            "$id": "#/videos/item/thumbnail",
            "description": "Generate and attach thumbnail for this video",
            "type": "boolean",
            "default": true
          },
          "movflags": {
            "$id": "#/videos/item/movflags",
            "description": "FFmpeg movflags option for MP4/MOV output",
            "type": "string",
            "examples": ["faststart", "+faststart+rtphint"]
          }
        },
        "required": ["input", "output"]
      },
      "uniqueItems": true
    }
  },
  "required": ["videos"]
}
